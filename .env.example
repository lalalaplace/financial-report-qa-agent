# PostgreSQL 配置：优先使用 DATABASE_URL
DATABASE_URL=postgresql+psycopg2://readonly_or_pipeline_user:change_me@localhost:5432/financial_data

# 也可以拆分配置，供 PDF 抽取脚本读取
DB_HOST=localhost
DB_PORT=5432
DB_NAME=financial_data
DB_USER=readonly_or_pipeline_user
DB_PASSWORD=change_me

# 本地数据目录，不提交真实文件
REPORT_ROOT=input/reports
OUTPUT_ROOT=output
KNOWN_OLD_REPORT_PREFIXES=

# Agent LLM 配置，兼容 OpenAI 协议的服务均可使用
AGENT_LLM_API_KEY=change_me
AGENT_LLM_MODEL=change_me
AGENT_LLM_BASE_URL=https://api.example.com/v1


# 真实 LLM 集成测试默认关闭
RUN_REAL_LLM_TESTS=0
